{
  "title": "CloudBot — Monitoring MySQL",
  "uid": "cloudbot-mysql",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Requêtes chat (total)",
      "type": "stat",
      "gridPos": {"x":0,"y":0,"w":6,"h":4},
      "targets": [{"expr":"sum(chatbot_requests_total)","refId":"A"}],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": 0}]
          },
          "noValue": "0"
        }
      }
    },
    {
      "id": 2,
      "title": "Taux d'erreurs (%)",
      "type": "stat",
      "gridPos": {"x":6,"y":0,"w":6,"h":4},
      "targets": [{"expr":"100 * sum(chatbot_requests_total{status='error'}) / sum(chatbot_requests_total)","refId":"A"}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "noValue": "0%",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 20}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Latence moyenne (s)",
      "type": "stat",
      "gridPos": {"x":12,"y":0,"w":6,"h":4},
      "targets": [{"expr":"rate(chatbot_request_duration_seconds_sum[5m]) / rate(chatbot_request_duration_seconds_count[5m])","refId":"A"}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "noValue": "0s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 30},
              {"color": "red", "value": 120}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Tokens générés (total)",
      "type": "stat",
      "gridPos": {"x":18,"y":0,"w":6,"h":4},
      "targets": [{"expr":"sum(chatbot_tokens_total)","refId":"A"}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "blue", "value": 0}]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Requêtes par minute",
      "type": "timeseries",
      "gridPos": {"x":0,"y":4,"w":12,"h":8},
      "targets": [
        {"expr":"rate(chatbot_requests_total{status='success'}[1m])*60","legendFormat":"Succès","refId":"A"},
        {"expr":"rate(chatbot_requests_total{status='error'}[1m])*60","legendFormat":"Erreurs","refId":"B"}
      ]
    },
    {
      "id": 6,
      "title": "CPU (%)",
      "type": "timeseries",
      "gridPos": {"x":12,"y":4,"w":12,"h":8},
      "targets": [{"expr":"100-(avg by(instance)(irate(node_cpu_seconds_total{mode='idle'}[5m]))*100)","legendFormat":"CPU","refId":"A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100}}
    },
    {
      "id": 7,
      "title": "Mémoire (Go)",
      "type": "timeseries",
      "gridPos": {"x":0,"y":12,"w":12,"h":8},
      "targets": [
        {"expr":"(node_memory_MemTotal_bytes-node_memory_MemAvailable_bytes)/1024/1024/1024","legendFormat":"RAM utilisée","refId":"A"},
        {"expr":"node_memory_MemTotal_bytes/1024/1024/1024","legendFormat":"RAM totale","refId":"B"}
      ],
      "fieldConfig": {"defaults": {"unit": "gbytes"}}
    },
    {
      "id": 8,
      "title": "MySQL — connexions actives",
      "type": "timeseries",
      "gridPos": {"x":12,"y":12,"w":12,"h":8},
      "targets": [
        {"expr":"mysql_global_status_threads_connected","legendFormat":"Connexions actives","refId":"A"},
        {"expr":"mysql_global_variables_max_connections","legendFormat":"Max connexions","refId":"B"}
      ]
    },
    {
      "id": 9,
      "title": "MySQL — Requêtes/s",
      "type": "timeseries",
      "gridPos": {"x":0,"y":20,"w":12,"h":8},
      "targets": [
        {"expr":"rate(mysql_global_status_queries[1m])","legendFormat":"Requêtes/s","refId":"A"},
        {"expr":"rate(mysql_global_status_slow_queries[1m])","legendFormat":"Lentes/s","refId":"B"}
      ]
    },
    {
      "id": 10,
      "title": "Trafic réseau (Mo/s)",
      "type": "timeseries",
      "gridPos": {"x":12,"y":20,"w":12,"h":8},
      "targets": [
        {"expr":"rate(node_network_receive_bytes_total[5m])/1024/1024","legendFormat":"Reçu {{device}}","refId":"A"},
        {"expr":"rate(node_network_transmit_bytes_total[5m])/1024/1024","legendFormat":"Envoyé {{device}}","refId":"B"}
      ],
      "fieldConfig": {"defaults": {"unit": "MBs"}}
    }
  ]
}